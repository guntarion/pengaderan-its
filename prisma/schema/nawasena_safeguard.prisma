// prisma/schema/nawasena_safeguard.prisma
// Domain: Safeguard & Insiden — M10
// Models: SafeguardIncident, ConsequenceLog, IncidentTimelineEntry, SafeguardEscalationFallback
// NAWASENA M10

// ============================================
// ENUMS — Safeguard & Incident
// ============================================

enum IncidentType {
  SAFE_WORD
  MEDICAL
  SHUTDOWN
  INJURY
  CONFLICT
  HARASSMENT
  OTHER
}

enum IncidentSeverity {
  GREEN
  YELLOW
  RED
}

enum IncidentStatus {
  PENDING_REVIEW
  OPEN
  IN_REVIEW
  RESOLVED
  ESCALATED_TO_SATGAS
  RETRACTED_BY_REPORTER
  RETRACTED_BY_SC
  SUPERSEDED
}

// ConsequenceType — STRICT: only non-physical, non-verbal, non-psychological values.
// NOT included (Permen 55/2024 prohibition):
//   - PUSH_UP, BERDIRI_LAMA, JUMPING_JACK, SQUAT_JUMP (hukuman fisik)
//   - BENTAK, CACIAN, PANGGILAN_MERENDAHKAN (kekerasan verbal)
//   - ISOLASI, DIAM_DI_SUDUT (psikologis)
enum ConsequenceType {
  REFLEKSI_500_KATA
  PRESENTASI_ULANG
  POIN_PASSPORT_DIKURANGI
  PERINGATAN_TERTULIS
  TUGAS_PENGABDIAN
}

enum ConsequenceStatus {
  ASSIGNED
  PENDING_REVIEW
  NEEDS_REVISION
  APPROVED
  OVERDUE
  FORFEITED
  CANCELLED
}

enum PassportCascadeStatus {
  NOT_APPLICABLE
  PENDING
  APPLIED
  FAILED
  SKIPPED_FLAG_OFF
}

enum TimelineAction {
  CREATED
  STATUS_CHANGED
  CLAIMED_FOR_REVIEW
  FIELD_UPDATED
  NOTE_ADDED
  ATTACHMENT_ADDED
  ATTACHMENT_DOWNLOADED
  CONSEQUENCE_ASSIGNED
  ESCALATED_TO_SATGAS
  SATGAS_PDF_GENERATED
  RESOLVED
  REOPENED
  RETRACTED_BY_REPORTER
  RETRACTED_BY_SC
  SUPERSEDED
  PEMBINA_ANNOTATION_ADDED
}

enum EscalationTarget {
  SATGAS_PPKPT_ITS
  DITMAWA_ITS
  EXTERNAL_LEGAL
}

// ============================================
// MODEL: SafeguardIncident — primary entity
// ============================================

model SafeguardIncident {
  id             String  @id @default(cuid())
  organizationId String
  cohortId       String
  kpGroupId      String? // nullable — context group-level incident from M03

  // Classification
  type     IncidentType
  severity IncidentSeverity
  status   IncidentStatus   @default(OPEN)

  // Timing
  occurredAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Narrative
  actionTaken String? @db.Text

  // Affected / Reported
  affectedUserId            String?
  additionalAffectedUserIds String[] @default([])
  reportedById              String

  // Claim / Resolution
  claimedById    String?
  claimedAt      DateTime?
  resolvedById   String?
  resolvedAt     DateTime?
  resolutionNote String?   @db.Text // min 30 chars when RESOLVED

  // Escalation
  escalatedTo      EscalationTarget?
  escalatedById    String?
  escalatedAt      DateTime?
  escalationReason String?           @db.Text // min 50 chars
  satgasTicketRef  String?
  satgasPdfKey     String?

  // Attachments
  attachmentKeys String[] @default([]) // S3 keys, max 3

  // Retraction
  retractedAt      DateTime?
  retractedById    String?
  retractionReason String?   @db.Text

  // Pembina annotations (append-only in app layer)
  pembinaAnnotations Json? // array of { pembinaId, note, createdAt }

  // Flexible metadata: source, kpLogDailyId, anecdote, etc.
  notes Json?

  // ---- Relations ----
  organization Organization @relation("OrgSafeguardIncidents", fields: [organizationId], references: [id])
  cohort       Cohort       @relation("CohortSafeguardIncidents", fields: [cohortId], references: [id])
  kpGroup      KPGroup?     @relation("KPGroupSafeguardIncidents", fields: [kpGroupId], references: [id])

  // Multi-relation to User — explicit names required
  affectedUser User? @relation("IncidentAffected", fields: [affectedUserId], references: [id])
  reportedBy   User  @relation("IncidentReporter", fields: [reportedById], references: [id])
  claimedBy    User? @relation("IncidentClaimer", fields: [claimedById], references: [id])
  resolvedBy   User? @relation("IncidentResolver", fields: [resolvedById], references: [id])
  escalatedBy  User? @relation("IncidentEscalator", fields: [escalatedById], references: [id])
  retractedBy  User? @relation("IncidentRetractor", fields: [retractedById], references: [id])

  timeline            IncidentTimelineEntry[]
  consequenceLogs     ConsequenceLog[]
  escalationFallbacks SafeguardEscalationFallback[]

  @@index([organizationId, status, severity])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, cohortId, status])
  @@index([affectedUserId])
  @@index([reportedById])
  @@index([claimedById])
  @@index([occurredAt(sort: Desc)])
  @@map("safeguard_incidents")
}

// ============================================
// MODEL: ConsequenceLog — Konsekuensi Pedagogis
// ============================================

model ConsequenceLog {
  id               String          @id @default(cuid())
  organizationId   String
  cohortId         String
  userId           String // target maba/KP
  type             ConsequenceType
  reasonText       String          @db.Text // min 30 chars
  forbiddenActCode String? // optional reference to forbidden_acts.csv

  relatedIncidentId String? // optional link to SafeguardIncident
  assignedById      String
  assignedAt        DateTime  @default(now())
  deadline          DateTime? // required for REFLEKSI/PRESENTASI/TUGAS_PENGABDIAN

  status        ConsequenceStatus @default(ASSIGNED)
  submittedAt   DateTime?
  notesAfter    String?           @db.Text // maba submission text
  attachmentKey String? // S3 key for submission file

  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?   @db.Text
  completedAt  DateTime?

  // POIN_PASSPORT_DIKURANGI specific
  pointsDeducted        Int?
  passportCascadeStatus PassportCascadeStatus @default(NOT_APPLICABLE)
  passportCascadeError  String?               @db.Text
  passportEntryId       String? // M05 PassportEntry.id reference after APPLIED

  // Cancellation
  cancelledAt   DateTime?
  cancelledById String?
  cancelReason  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ---- Relations ----
  organization    Organization       @relation("OrgConsequenceLogs", fields: [organizationId], references: [id])
  cohort          Cohort             @relation("CohortConsequenceLogs", fields: [cohortId], references: [id])
  user            User               @relation("ConsequenceTarget", fields: [userId], references: [id])
  assignedBy      User               @relation("ConsequenceAssigner", fields: [assignedById], references: [id])
  reviewedBy      User?              @relation("ConsequenceReviewer", fields: [reviewedById], references: [id])
  cancelledBy     User?              @relation("ConsequenceCanceller", fields: [cancelledById], references: [id])
  relatedIncident SafeguardIncident? @relation(fields: [relatedIncidentId], references: [id])

  @@index([organizationId, userId, status])
  @@index([organizationId, assignedById, createdAt(sort: Desc)])
  @@index([organizationId, status, deadline])
  @@index([relatedIncidentId])
  @@index([type])
  @@map("consequence_logs")
}

// ============================================
// MODEL: IncidentTimelineEntry — append-only audit trail
// ============================================

model IncidentTimelineEntry {
  id             String @id @default(cuid())
  organizationId String // denormalized for RLS + fast query
  incidentId     String
  actorId        String

  action    TimelineAction
  oldValue  Json? // state before (STATUS_CHANGED, FIELD_UPDATED)
  newValue  Json? // state after or new payload
  fieldName String? // for FIELD_UPDATED: which field changed
  noteText  String?        @db.Text // for NOTE_ADDED, PEMBINA_ANNOTATION_ADDED

  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  // ---- Relations ----
  organization Organization      @relation("OrgTimelineEntries", fields: [organizationId], references: [id])
  incident     SafeguardIncident @relation(fields: [incidentId], references: [id])
  actor        User              @relation("TimelineActor", fields: [actorId], references: [id])

  @@index([incidentId, createdAt])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action])
  @@map("incident_timeline_entries")
}

// ============================================
// MODEL: SafeguardEscalationFallback — log direct dispatch when M15 degraded
// ============================================

model SafeguardEscalationFallback {
  id             String @id @default(cuid())
  organizationId String
  incidentId     String
  receiverUserId String

  channel      ChannelType
  status       String // SENT | FAILED
  attemptedAt  DateTime    @default(now())
  errorMessage String?     @db.Text
  m15Attempted Boolean // true = fallback because M15 failed; false = feature flag off

  // ---- Relations ----
  organization Organization      @relation("OrgEscalationFallbacks", fields: [organizationId], references: [id])
  incident     SafeguardIncident @relation(fields: [incidentId], references: [id])
  receiver     User              @relation("EscalationFallbackReceiver", fields: [receiverUserId], references: [id])

  @@index([organizationId, attemptedAt(sort: Desc)])
  @@index([incidentId])
  @@map("safeguard_escalation_fallbacks")
}
