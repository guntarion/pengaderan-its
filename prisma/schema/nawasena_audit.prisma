// prisma/schema/nawasena_audit.prisma
// Domain: NawasenaAuditLog (NAWASENA-specific audit log, replaces generic AuditLog for scoped ops)
// NAWASENA M01

// ============================================
// ENUMS — Audit
// ============================================

enum AuditAction {
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  USER_ROLE_CHANGE
  USER_BULK_IMPORT
  USER_EMERGENCY_CONTACT_ACCESSED
  ORG_CREATE
  ORG_UPDATE
  ORG_ARCHIVE
  COHORT_CREATE
  COHORT_UPDATE
  COHORT_ARCHIVE
  PAKTA_VERSION_PUBLISH
  PAKTA_SIGN
  PAKTA_REJECT
  PAKTA_RESIGN_TRIGGER
  WHITELIST_ADD
  WHITELIST_REMOVE
  LOGIN
  LOGOUT
  SESSION_REVOKE
  SUPERADMIN_CROSS_ORG_ACCESS
  FULL_DELETE_USER
  EMERGENCY_BULK_SIGN
  // M02: Master Data operations
  MASTER_DATA_SEED
  MASTER_DATA_SEED_FAILED
  TAXONOMY_META_UPDATE
  KEGIATAN_TOGGLE_ACTIVE
  PUBLIC_CATALOG_TOGGLED
  // M15: Notification operations
  NOTIFICATION_RULE_CREATE
  NOTIFICATION_RULE_UPDATE
  NOTIFICATION_RULE_DELETE
  NOTIFICATION_TEMPLATE_PUBLISH
  NOTIFICATION_PREFERENCE_UPDATE
  CRON_MANUAL_TRIGGER
  // M03: Struktur Angkatan — KP Group, Buddy, Kasuh
  KP_GROUP_CREATE
  KP_GROUP_UPDATE
  KP_GROUP_ARCHIVE
  KP_GROUP_ASSIGN_MEMBER
  KP_GROUP_REMOVE_MEMBER
  KP_GROUP_COORDINATOR_REPLACE
  BUDDY_PAIR_CREATE
  BUDDY_PAIR_SWAP
  BUDDY_PAIR_ARCHIVE
  KASUH_PAIR_CREATE
  KASUH_PAIR_REASSIGN
  KASUH_PAIR_ARCHIVE
  PAIRING_REQUEST_CREATE
  PAIRING_REQUEST_APPROVE
  PAIRING_REQUEST_REJECT
  PAIRING_REQUEST_FULFILL
  PAIRING_REQUEST_CANCEL
  BULK_PAIRING_COMMIT
}

enum DemographicField {
  IS_RANTAU
  IS_KIP
  HAS_DISABILITY
  PROVINCE
  EMERGENCY_CONTACT
}

// ============================================
// MODEL: NawasenaAuditLog (append-only, dual actor/subject)
// ============================================

model NawasenaAuditLog {
  id             String      @id @default(cuid())
  organizationId String?     // nullable for platform-level actions
  action         AuditAction
  actorUserId    String?     // null for system actions
  subjectUserId  String?     // for role change, pakta sign, etc.
  entityType     String      // "User", "Cohort", "PaktaSignature", ...
  entityId       String      // UUID as string
  beforeValue    Json?       // snapshot before change
  afterValue     Json?       // snapshot after change
  reason         String?     @db.Text // required for role change, cross-org, full delete
  ipAddress      String?
  userAgent      String?     @db.Text
  metadata       Json?       // additional context: file hash for bulk import, target org, etc.
  createdAt      DateTime    @default(now())

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id])
  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id])
  subject      User?         @relation("AuditSubject", fields: [subjectUserId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([subjectUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("nawasena_audit_logs")
}
