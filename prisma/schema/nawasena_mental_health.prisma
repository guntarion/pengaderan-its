// prisma/schema/nawasena_mental_health.prisma
// Domain: Mental Health Screening — Privacy-Critical module (NAWASENA M11)
// 8 models: MHScreening, MHScreeningAnswer, MHReferralLog, MHReferralTimeline,
//           MHAccessLog, MHConsentRecord, MHResearchConsent, MHDeletionRequest
// 6 enums: MHInstrument, MHSeverity, MHScreeningPhase, MHReferralStatus,
//          MHAccessAction, MHConsentStatus
//
// PRIVACY-CRITICAL: All sensitive fields are encrypted via pgcrypto column-level.
// RLS policies enforce 3-pathway access (self / assigned SAC / escalated coordinator).
// Audit log (MHAccessLog) is immutable append-only.
//
// RLS + pgcrypto policies added manually to migration SQL — see migration.

// ============================================
// ENUMS — Mental Health
// ============================================

enum MHInstrument {
  PHQ9   // Depression screening 9-item (V1)
  GAD7   // Anxiety screening 7-item (V2)
  DASS21 // Depression/Anxiety/Stress 21-item short (V3)
}

enum MHSeverity {
  GREEN  // Minimal/none — no referral
  YELLOW // Mild/moderate — flagged for monitoring, no auto-referral
  RED    // Severe — auto-referral SAC
}

enum MHScreeningPhase {
  F1             // Minggu 2 cohort (default screening)
  F4             // Re-screen akhir cohort
  SELF_TRIGGERED // Maba klik "Cek kondisi saya" (V2)
}

enum MHReferralStatus {
  PENDING     // Created, waiting SAC pickup
  IN_PROGRESS // SAC acknowledged, active follow-up
  RESOLVED    // Case closed with resolution note
  REASSIGNED  // Transferred to another SAC (history preserved)
  TAKEN_OVER  // Coordinator takes over after escalation
  CANCELLED   // Maba withdrawal & deletion (rare)
}

enum MHAccessAction {
  READ_META          // View metadata (cohort, phase, severity) without decrypt
  DECRYPT_SCORE      // Decrypt rawScoreEncrypted
  DECRYPT_ANSWERS    // Decrypt per-item answers
  DECRYPT_NOTE       // Decrypt SAC note
  STATUS_CHANGE      // Referral status transition
  EXPORT_AGGREGATE   // CSV export aggregate
  BYPASS_RLS         // Admin bypass for maintenance
  CONSENT_RECORDED   // Maba consent submit
  CONSENT_WITHDRAWN  // Maba withdraw consent
  DATA_DELETED       // Retention delete or user-request delete
  KEY_ROTATED        // Admin re-encrypt with new key
  AUDIT_REVIEW       // Superadmin reviewing audit log itself
}

enum MHConsentStatus {
  GRANTED          // Active consent
  WITHDRAWN        // Withdrawn (data pending deletion)
  EXPIRED_VERSION  // Consent text version bumped, re-consent needed
}

// ============================================
// MODEL: MHScreening — one PHQ9/GAD7/DASS21 submission by Maba
// ============================================

model MHScreening {
  id                   String            @id @default(cuid())
  userId               String
  cohortId             String
  organizationId       String
  kpGroupId            String?           // snapshot at submit time, nullable if not yet assigned

  instrument           MHInstrument
  phase                MHScreeningPhase

  // Encrypted via pgcrypto — plain bytes in Postgres, decrypted only via helper
  rawScoreEncrypted    Bytes

  // Plain fields for RLS decision + aggregate (no PII in these fields)
  severity             MHSeverity
  flagged              Boolean           @default(false) // borderline YELLOW or special item
  immediateContact     Boolean           @default(false) // PHQ-9 item #9 > 0 → SLA 24h

  encryptionKeyVersion Int               @default(1)     // track key rotation
  consentId            String

  recordedAt           DateTime          @default(now())
  deletedAt            DateTime?         // soft-delete marker; retention cron hard-deletes after 30d
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  // Relations
  user         User              @relation(fields: [userId], references: [id])
  cohort       Cohort            @relation(fields: [cohortId], references: [id])
  organization Organization      @relation(fields: [organizationId], references: [id])
  consent      MHConsentRecord   @relation(fields: [consentId], references: [id])
  answers      MHScreeningAnswer[]
  referral     MHReferralLog?

  // Unique: one submission per (user, cohort, phase, instrument)
  @@unique([userId, cohortId, phase, instrument])
  @@index([cohortId, phase, severity])
  @@index([userId, cohortId])
  @@index([kpGroupId, phase, severity])
  @@index([organizationId])
  @@map("mh_screenings")
}

// ============================================
// MODEL: MHScreeningAnswer — per-item encrypted answer
// ============================================

model MHScreeningAnswer {
  id                      String      @id @default(cuid())
  screeningId             String
  questionIndex           Int         // 0-based (0-8 for PHQ-9)
  answerValueEncrypted    Bytes       // pgcrypto encrypt of "0"|"1"|"2"|"3"
  encryptionKeyVersion    Int         @default(1)
  createdAt               DateTime    @default(now())

  screening MHScreening @relation(fields: [screeningId], references: [id], onDelete: Cascade)

  @@unique([screeningId, questionIndex])
  @@map("mh_screening_answers")
}

// ============================================
// MODEL: MHReferralLog — auto-referral to SAC when RED
// ============================================

model MHReferralLog {
  id               String            @id @default(cuid())
  screeningId      String            @unique
  userId           String            // Maba (denormalized for RLS perf)
  organizationId   String

  referredAt        DateTime          @default(now())
  referredToId      String            // FK → User (SAC counselor)
  assignmentReason  String            @default("AUTO_ROUND_ROBIN")

  slaDeadlineAt    DateTime           // referredAt + 72h (or 24h for immediateContact)
  status           MHReferralStatus

  statusChangedAt  DateTime          @default(now())
  acknowledgedAt   DateTime?         // when SAC first accesses (transition to IN_PROGRESS)
  resolutionAt     DateTime?         // when RESOLVED

  // Encrypted note
  resolutionNoteEncrypted Bytes?
  encryptionKeyVersion    Int         @default(1)

  escalatedAt      DateTime?         // set by SLA miss cron
  takenOverById    String?           // FK → User (Coordinator)
  reassignedFromId String?           // FK → User (previous SAC)
  reassignedReason String?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  screening     MHScreening               @relation(fields: [screeningId], references: [id])
  user          User                      @relation("MHReferralsMaba", fields: [userId], references: [id])
  referredTo    User                      @relation("MHReferralsSAC", fields: [referredToId], references: [id])
  takenOverBy   User?                     @relation("MHReferralsTakenOver", fields: [takenOverById], references: [id])
  organization  Organization              @relation(fields: [organizationId], references: [id])
  timeline      MHReferralTimeline[]

  @@index([referredToId, status, slaDeadlineAt])
  @@index([status, slaDeadlineAt])
  @@index([escalatedAt])
  @@index([userId])
  @@index([organizationId])
  @@map("mh_referral_logs")
}

// ============================================
// MODEL: MHReferralTimeline — append-only timeline per referral
// ============================================

model MHReferralTimeline {
  id                   String    @id @default(cuid())
  referralId           String
  actorId              String    // FK → User (SAC/coordinator/system)
  action               String    // CREATED, ACKNOWLEDGED, NOTE_ADDED, STATUS_CHANGED, REASSIGNED, ESCALATED, TAKEN_OVER, M10_REFERRED
  payloadEncrypted     Bytes?    // Optional encrypted payload for notes
  metadata             Json?     // Non-sensitive meta (previous status, new status, reason)
  encryptionKeyVersion Int       @default(1)
  createdAt            DateTime  @default(now())

  referral MHReferralLog @relation(fields: [referralId], references: [id])

  @@index([referralId, createdAt])
  @@map("mh_referral_timelines")
}

// ============================================
// MODEL: MHAccessLog — immutable audit log (append-only enforced via RLS + GRANT)
// ============================================

model MHAccessLog {
  id             String          @id @default(cuid())
  actorId        String
  actorRole      UserRole        // snapshot role at time of access
  action         MHAccessAction
  targetType     String          // MHScreening, MHReferralLog, MHScreeningAnswer, etc.
  targetId       String?
  targetUserId   String?         // denormalized: Maba whose data was accessed (forensic)
  organizationId String?
  reason         String?
  ipHash         String?         // SHA-256 of IP (not plain)
  userAgent      String?         // truncated to 200 chars
  metadata       Json?           // non-sensitive meta only; NEVER plaintext payload
  createdAt      DateTime        @default(now())

  // Note: NO updatedAt (append-only)
  actor User @relation("MHAccessActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
  @@index([organizationId, createdAt])
  @@map("mh_access_logs")
}

// ============================================
// MODEL: MHConsentRecord — per-cohort screening consent
// ============================================

model MHConsentRecord {
  id              String            @id @default(cuid())
  userId          String
  cohortId        String
  consentVersion  String            // e.g., "v1.0" — references src/content/mh-consent/v1.md
  status          MHConsentStatus
  grantedAt       DateTime          @default(now())
  withdrawnAt     DateTime?
  withdrawalReason String?
  ipHash          String?           // SHA-256 of IP at time of consent
  userAgent       String?
  scope           Json              // { screening: true, research: false }
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  user       User           @relation(fields: [userId], references: [id])
  cohort     Cohort         @relation(fields: [cohortId], references: [id])
  screenings MHScreening[]

  @@unique([userId, cohortId, consentVersion])
  @@index([userId, status])
  @@map("mh_consent_records")
}

// ============================================
// MODEL: MHResearchConsent — opt-in research retention (2-year)
// ============================================

model MHResearchConsent {
  id                     String    @id @default(cuid())
  userId                 String
  cohortId               String
  consentVersion         String    // research-specific consent text version
  scope                  String[]  // e.g., ["aggregate_analysis", "publication_anonym"]
  retentionExtendedUntil DateTime  // grantedAt + 2 years
  withdrawnAt            DateTime?
  createdAt              DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  cohort Cohort @relation(fields: [cohortId], references: [id])

  @@map("mh_research_consents")
}

// ============================================
// MODEL: MHDeletionRequest — user deletion request with 7-day grace
// ============================================

model MHDeletionRequest {
  id                String    @id @default(cuid())
  userId            String
  requestedAt       DateTime  @default(now())
  scheduledDeleteAt DateTime  // requestedAt + 7 days grace
  processedAt       DateTime?
  blockedByReason   String?   // "Active RED referral" etc.
  overrideBy        String?   // Coordinator who reviewed safety override
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("mh_deletion_requests")
}
